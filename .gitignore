# PiQPull .gitignore

# ── Face images — NOT redistributable ───────────────────────────────────────
# Copyright notice: face images for orb characters are not included in this
# repo. Each user supplies their own. See README.md — Face Images section.
chrome/characters/*/face.png
chrome/characters/**/*.png
chrome/characters/**/*.jpg
chrome/characters/**/*.jpeg
chrome/characters/**/*.webp
chrome/characters/**/*.gif

# Original character PNGs (kept for backward compat with pre-1.2.0 layout)
chrome/beavis.png
chrome/butthead.png

# ── Local / dev scratch ───────────────────────────────────────────────────────
_local/
TempOutput/
*.local.*

# ── Node / build artifacts ────────────────────────────────────────────────────
node_modules/
dist/
build/
.cache/

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/settings.json
.idea/

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
*.env.local
secrets.*

# ── Test exports (bulk downloads for debugging) ───────────────────────────────
*.zip
chrome/_local/
